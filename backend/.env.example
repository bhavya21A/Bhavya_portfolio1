# CHANGE HERE: Copy this file to .env, then replace placeholder values with your real keys.
PORT=5000
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# MongoDB contact storage
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio
MONGODB_DB_NAME=portfolio

# Supabase placeholders for future migration
