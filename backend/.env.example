SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notification placeholders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=bhavyashukla759@gmail.com
SMTP_PASS=your-app-password
NOTIFY_TO=bhavyashukla759@gmail.com
